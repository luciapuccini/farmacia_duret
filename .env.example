# --- Public vars -- #
NEXTJS_ENV=development
NEXT_PUBLIC_SITE_URL=https://farmaciaduret.online

# Whatsapp
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER=15556438703

# --- Private runtime/ build secrets -- #
# Contentful
CONTENTFUL_SPACE_ID=your_contentful_space_id
CONTENTFUL_DELIVERY_TOKEN=your_contentful_delivery_token
CONTENTFUL_ENVIRONMENT=master
# Whatsapp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=generate_a_private_random_token
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_GRAPH_API_VERSION=v25.0

# Non-secret runtime identifiers. Required for WhatsApp Cloud API order sends.
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_meta_business_account_id
WHATSAPP_ORDER_RECIPIENT_PHONE_NUMBER=recipient_phone_number_in_international_format
WHATSAPP_ORDER_TEMPLATE_NAME=your_approved_order_template_name
WHATSAPP_ORDER_IMAGE_TEMPLATE_NAME=your_approved_order_template_with_image_header
WHATSAPP_ORDER_TEMPLATE_LANGUAGE=es_AR
