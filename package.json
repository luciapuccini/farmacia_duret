{
  "name": "farmacia_duret",
  "private": true,
  "version": "0.0.0",
  "license": "MPL-2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "fallow:audit": "git diff --cached --unified=0 --no-ext-diff --relative | fallow audit --gate all --diff-file - --fail-on-issues",
    "fallow": "fallow audit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "whatsapp:token:generate": "node -e \"console.log(require('node:crypto').randomBytes(24).toString('hex'))\"",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare deploy",
    "deploy:stg": "opennextjs-cloudflare deploy --env stg"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sass": "^1.98.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fallow": "^2.82.0",
    "globals": "^16.5.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-merge": "^3.6.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.36.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
